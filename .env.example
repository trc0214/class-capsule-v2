# 課堂膠囊 - 環境變量配置範例
# 複製此文件為 .env.local 並填入您的實際 API 密鑰
# .env.local 會被 git 忽略，不會上傳到倉庫

# ===========================
# Azure Speech Service 配置
# ===========================
# Region: japaneast (日本東部)
# Tier: Standard (不能使用 Free)
# 獲取方式: https://portal.azure.com
AZURE_SPEECH_KEY=your_azure_speech_api_key_here
AZURE_SPEECH_REGION=japaneast

# ===========================
# Google Gemini API 配置
# ===========================
# 獲取方式: https://aistudio.google.com
GEMINI_API_KEY=your_gemini_api_key_here

# ===========================
# 應用配置 (可選)
# ===========================
# 語言設置 (zh-CN, zh-TW, en-US 等)
APP_LANGUAGE=zh-CN

# 開發模式 (true/false)
DEBUG_MODE=false

# ===========================
# 部署配置 (可選)
# ===========================
# 應用的公開 URL (用於共享、Vercel 等)
PUBLIC_URL=http://localhost:8000
